# RPC endpoints. Recommended: MetaMask Developer / Infura (developer.metamask.io).
# Infura provides archive node access, which the /v1/events and /v1/block endpoints
# rely on for querying historical state past public-RPC retention windows.
# Format: https://<chain>.infura.io/v3/<API_KEY>
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Server config
PORT=3000

# Cache TTL in seconds for read endpoints
CACHE_TTL=10

# Rate limit: requests per minute per IP
RATE_LIMIT_RPM=60
